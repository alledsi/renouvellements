# Configuration du frontend Django (copier en `.env` sur chaque environnement)
# Ce fichier .env est ignoré par git (voir .gitignore) : il ne sera JAMAIS
# écrasé par un `git pull` et reste propre à chaque machine.

# URL du backend FastAPI.
#  - En local :        http://localhost:8008
#  - Sur le serveur :  http://192.168.0.122:8008
FASTAPI_URL=http://localhost:8008
